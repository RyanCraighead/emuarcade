{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "emuarcade",
  "permissions": {
    "http": {
      "enable": true,
      "domains": ["i.redd.it", "preview.redd.it"]
    },
    "media": true,
    "redis": true,
    "reddit": {
      "asUser": ["SUBMIT_POST", "SUBMIT_COMMENT"]
    }
  },
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "height": "regular",
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      },
      "shared": {
        "inline": true,
        "height": "regular",
        "entry": "shared.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Create EmuArcade post",
        "description": "Create a new EmuArcade custom post",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  },
  "dev": {
    "subreddit": "emuarcade_dev"
  }
}
